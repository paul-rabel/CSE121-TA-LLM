# Crawl source pages (required only when running firecrawl_crawler.py)
FIRECRAWL_API_KEY=

# LLM settings
# Set to 0 for deterministic/extractive-only mode.
ENABLE_LLM_RESPONSE=1

# Ollama settings
# Leave OLLAMA_MODEL empty to auto-select the first installed model from `ollama list`.
# Example explicit model values:
#   OLLAMA_MODEL=llama3.2:3b
#   OLLAMA_MODEL=mistral:latest
OLLAMA_MODEL=
# Optional role-specific models for premium two-stage mode.
# If left empty, each role falls back to OLLAMA_MODEL/auto-discovery.
OLLAMA_ROUTER_MODEL=
OLLAMA_READER_MODEL=
# Optional checker model for blocking code-feedback/debugging requests.
OLLAMA_CHECKER_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECS=45
OLLAMA_TAGS_TIMEOUT_SECS=3
LLM_CONTEXT_MODE=retrieval
LLM_FULL_CONTEXT_MAX_CHARS=160000
LLM_SECTION_MAP_EXPANDED_SECTIONS=8
LLM_TRACE_MAX_CHARS=24000
PREMIUM_ROUTER_MAX_CANDIDATES=24
PREMIUM_ROUTER_TOP_SOURCES=2
PREMIUM_READER_MAX_CONTEXT_CHARS=90000
ENABLE_CODE_GUARD_CHECKER=1

# Retrieval/memory settings (optional)
ENABLE_DENSE_RETRIEVAL=0
ENABLE_SESSION_MEMORY=1
ENABLE_CLARIFICATION_STITCH=1
DEBUG_SOURCE_DETAILS=0
